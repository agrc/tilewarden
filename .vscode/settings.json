{
  "python-envs.defaultEnvManager": "ms-python.python:conda",
  "python.testing.pytestArgs": ["tests"],
  "python.testing.unittestEnabled": false,
  "python.testing.pytestEnabled": true,
  "cSpell.words": [
    "EPSG",
    "geopackage",
    "geopandas",
    "geospatial",
    "mininterval",
    "pyproject",
    "pytest",
    "pythonpath",
    "testpaths",
    "tilewarden",
    "tqdm",
    "venv",
    "webmercator",
    "wkid",
    "WMTS"
  ],
  "chat.tools.terminal.autoApprove": {
    "/^conda activate tilewarden && ruff check \\. && ruff format --check \\.$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "/^conda activate tilewarden && python -m pytest$/": {
      "approve": true,
      "matchCommandLine": true
    }
  }
}
